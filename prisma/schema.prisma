generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============ ENUMS ============

enum Role {
  ADMIN
  COMERCIAL
  TECNICO
  CLIENTE
}

enum LeadStatus {
  NOVO
  QUALIFICADO
  CONTATADO
  PROPOSTA
  GANHO
  PERDIDO
}

enum LeadSource {
  ORGANICO
  PAGO
  REFERRAL
  WHATSAPP
  CATALOGO
  CALCULADORA
  COMPARATIVO
  FORMULARIO
}

enum ProductCategory {
  TOMBADOR_FIXO
  TOMBADOR_MOVEL
  COLETOR_AMOSTRAS
  UNIDADE_TRANSBORDO
  ESPECIAL
}

enum Locale {
  pt_BR @map("pt-BR")
  en
  es
}

// ============ AUTH ============

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(CLIENTE)
  company       String?
  phone         String?
  cpfCnpj       String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ PRODUTOS ============

model Product {
  id           String               @id @default(cuid())
  slug         String               @unique
  category     ProductCategory
  order        Int                  @default(0)
  active       Boolean              @default(true)
  featured     Boolean              @default(false)
  translations ProductTranslation[]
  specs        Spec[]
  features     Feature[]
  media        Media[]
  faqs         FAQ[]
  applications Application[]        @relation("ProductApplications")
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model ProductTranslation {
  id          String  @id @default(cuid())
  productId   String
  locale      Locale
  name        String
  tagline     String?
  description String  @db.Text
  metaTitle   String?
  metaDesc    String?
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
}

model Spec {
  id        String  @id @default(cuid())
  productId String
  key       String
  value     String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Feature {
  id          String  @id @default(cuid())
  productId   String
  locale      Locale
  title       String
  description String  @db.Text
  icon        String?
  order       Int     @default(0)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model FAQ {
  id        String   @id @default(cuid())
  productId String?
  locale    Locale
  question  String
  answer    String   @db.Text
  order     Int      @default(0)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Application {
  id           String                   @id @default(cuid())
  slug         String                   @unique
  translations ApplicationTranslation[]
  products     Product[]                @relation("ProductApplications")
  cases        Case[]
}

model ApplicationTranslation {
  id            String      @id @default(cuid())
  applicationId String
  locale        Locale
  name          String
  description   String      @db.Text
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, locale])
}

// ============ MEDIA ============

model Media {
  id        String   @id @default(cuid())
  productId String?
  caseId    String?
  url       String
  alt       String?
  type      String
  width     Int?
  height    Int?
  order     Int      @default(0)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  case      Case?    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

// ============ CASES / OBRAS ============

model Case {
  id            String            @id @default(cuid())
  slug          String            @unique
  applicationId String?
  client        String
  location      String
  year          Int
  active        Boolean           @default(true)
  featured      Boolean           @default(false)
  translations  CaseTranslation[]
  media         Media[]
  metrics       CaseMetric[]
  application   Application?      @relation(fields: [applicationId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model CaseTranslation {
  id      String @id @default(cuid())
  caseId  String
  locale  Locale
  title   String
  summary String @db.Text
  content String @db.Text
  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, locale])
}

model CaseMetric {
  id     String @id @default(cuid())
  caseId String
  label  String
  value  String
  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

// ============ BLOG ============

model Post {
  id           String            @id @default(cuid())
  slug         String            @unique
  author       String            @default("PILI Industrial")
  cover        String?
  published    Boolean           @default(false)
  publishedAt  DateTime?
  translations PostTranslation[]
  tags         String[]          @default([])
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model PostTranslation {
  id        String @id @default(cuid())
  postId    String
  locale    Locale
  title     String
  excerpt   String @db.Text
  content   String @db.Text
  metaTitle String?
  metaDesc  String?
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
}

// ============ LEADS ============

model Lead {
  id              String     @id @default(cuid())
  name            String
  email           String
  phone           String
  company         String?
  cnpj            String?
  country         String     @default("BR")
  state           String?
  city            String?
  role            String?
  application     String?
  productId       String?
  productInterest String?
  grainType       String?
  truckVolume     Int?
  message         String?    @db.Text
  source          LeadSource @default(FORMULARIO)
  utm             Json?
  pageUrl         String?
  status          LeadStatus @default(NOVO)
  assignedTo      String?
  notes           Note[]
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  leadId    String
  authorId  String
  content   String   @db.Text
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

// ============ JOB POSTINGS ============

model Job {
  id           String           @id @default(cuid())
  slug         String           @unique
  active       Boolean          @default(true)
  translations JobTranslation[]
  applications JobApplication[]
  createdAt    DateTime         @default(now())
}

model JobTranslation {
  id          String @id @default(cuid())
  jobId       String
  locale      Locale
  title       String
  area        String
  description String @db.Text
  job         Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, locale])
}

model JobApplication {
  id        String   @id @default(cuid())
  jobId     String
  name      String
  email     String
  phone     String
  cvUrl     String
  message   String?  @db.Text
  createdAt DateTime @default(now())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

// ============ PORTAL CLIENTE ============

model ClientEquipment {
  id               String         @id @default(cuid())
  userId           String
  serialNumber     String         @unique
  productName      String
  installedAt      DateTime
  installedAddress String?
  warrantyEndsAt   DateTime?
  serviceOrders    ServiceOrder[]
  createdAt        DateTime       @default(now())
}

model ServiceOrder {
  id          String          @id @default(cuid())
  equipmentId String
  number      String          @unique
  type        String
  status      String
  description String          @db.Text
  scheduledAt DateTime?
  completedAt DateTime?
  equipment   ClientEquipment @relation(fields: [equipmentId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
